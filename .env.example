# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn OAuth app credentials
# Create an app at https://www.linkedin.com/developers/apps/new
# Required scopes: openid, profile, w_member_social
# Add http://localhost:8000/callback as an authorized redirect URL
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# LinkedIn access token and person URN
# Run oauth_helper.py once to generate these
LINKEDIN_ACCESS_TOKEN=AQX...
LINKEDIN_PERSON_URN=urn:li:person:...
